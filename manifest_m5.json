    "disable_features": [
      "simd",
      "bulk-memory",
      "reference-types"
    ],
    "features_note": "IDENTICAL guardrail to manifest_m0/m2/m3.json - the flags are FROZEN. M5 does not enable anything: files whose syntax the pinned WABT 1.0.41 rejects under these flags (GC/function-references/tail-call/multi-memory/annotations/bulk-memory/reference-types/64-bit offsets) are CONVERT-FAIL by design and stay out of executable scope. Output paths are DISJOINT from the frozen toolchain: build/converted_m5/<stem>/ and build/report/m5_*.json only."
  },
